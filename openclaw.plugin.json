{
  "id": "vestige-bridge",
  "name": "Vestige Bridge",
  "description": "Bridge recent cognitive memory from a Vestige sidecar into OpenClaw runtime hooks.",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": {
        "type": "boolean",
        "description": "Enable Vestige Bridge runtime hooks."
      },
      "enabledAgents": {
        "type": "array",
        "items": { "type": "string" },
        "description": "Only these agent ids use Vestige recall. Empty or omitted means all agents."
      },
      "baseUrl": {
        "type": "string",
        "description": "Base URL for the Vestige MCP HTTP transport."
      },
      "authTokenPath": {
        "type": "string",
        "description": "Path to the Vestige MCP auth token file when VESTIGE_AUTH_TOKEN is not set."
      },
      "timeoutMs": {
        "type": "integer",
        "minimum": 100,
        "description": "HTTP timeout for sidecar requests in milliseconds."
      },
      "debug": {
        "type": "boolean",
        "description": "Enable verbose plugin logging."
      },
      "recall": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "maxResults": { "type": "integer", "minimum": 1 },
          "maxTokens": { "type": "integer", "minimum": 1 },
          "softTarget": { "type": "integer", "minimum": 1 },
          "hardCap": { "type": "integer", "minimum": 1 },
          "skipMaterialized": { "type": "boolean" },
          "maxTailMessages": { "type": "integer", "minimum": 1 }
        }
      },
      "export": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "rootDir": {
            "type": "string",
            "description": "Root directory for explicit export snapshots."
          },
          "tmpSuffix": {
            "type": "string",
            "description": "Temporary suffix used for atomic export writes."
          },
          "enableExplicit": {
            "type": "boolean",
            "description": "Enable the explicit export runtime helper."
          }
        }
      },
      "packing": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "bucketPriority": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Priority order used by recent-memory packing."
          }
        }
      },
      "behavior": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "failSoft": {
            "type": "boolean",
            "description": "Log and continue instead of throwing on sidecar failures."
          },
          "enableAgentEndIngest": {
            "type": "boolean",
            "description": "Enable best-effort smart-ingest during agent_end."
          }
        }
      }
    }
  },
  "uiHints": {
    "enabled": { "label": "Enabled" },
    "enabledAgents": { "label": "Enabled Agents" },
    "baseUrl": { "label": "Sidecar Base URL" },
    "timeoutMs": { "label": "Timeout (ms)" },
    "debug": { "label": "Debug Logging" },
    "recall": { "label": "Recall" },
    "export": { "label": "Export" },
    "packing": { "label": "Packing" },
    "behavior": { "label": "Behavior" }
  }
}
